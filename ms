        canvas.style.background = "url('https://cdn.jsdelivr.net/gh/fnafben/4z5@main/background.png') center / cover";

        loadingCover.style.display = "";

        document.addEventListener('contextmenu', event => event.preventDefault());

        function FocusGame() {
            window.focus();
            canvas.focus();
