lid rgba(255,255,255,.8);box-shadow:inset 2px 2px 6px rgba(255,255,255,.6),inset -2px -2px 6px rgba(0,0,0,.2),0 0 10px rgba(120,200,255,.25);border-radius:3px;animation:fall 6s linear infinite,spin 3s linear infinite}@keyframes fall{0%{transform:translateY(-30px);opacity:0}10%{opacity:1}100%{transform:translateY(120vh);opacity:0}}@keyframes spin{0%{transform:rotateX(0) rotateY(0)}100%{transform:rotateX(360deg) rotateY(360deg)}}.container{width:1100px;max-width:95%;margin:auto;background:rgba(10,20,35,.55);backdrop-filter:blur(18px);border:1px solid rgba(120,180,220,.25);border-radius:24px;padding:30px;box-shadow:0 20px 60px rgba(0,0,0,.6),inset 0 0 20px rgba(255,255,255,.05);position:relative;overflow:hidden}.container::before{content:"";position:absolute;inset:0;background:linear-gradient(120deg,transparent 49%,rgba(120,180,220,.15) 50%,transparent 51%),linear-gradient(35deg,transparent 60%,rgba(120,180,220,.10) 61%,transparent 62%),linear-gradient(160deg,transparent 70%,rgba(120,180,220,.08) 71%,transparent 72%);opacity:.4;pointer-events:none}.top-bar{display:flex;gap:15px;margin-bottom:30px}.search{flex:1;height:45px;border:none;border-radius:10px;padding:0 15px;font-size:16px;outline:none}.random-btn{width:110px;border:none;border-radius:10px;background:#5c4dff;color:#fff;font-size:16px;cursor:pointer;transition:.25s}.random-btn:hover{background:#766aff}.movie-grid{display:grid;grid-template-columns:repeat(auto-fill,minmax(110px,1fr));gap:12px}.movie-card{position:relative;aspect-ratio:1/1;border:none;border-radius:12px;overflow:hidden;cursor:pointer;background:#1b1b1b;transition:.25s ease;text-decoration:none}.movie-card img{width:100%;height:100%;object-fit:cover;display:block}.movie-card:hover{transform:translateY(-5px) scale(1.03);box-shadow:0 0 20px rgba(120,200,255,.25),0 10px 25px rgba(0,0,0,.6)}.movie-name{position:absolute;bottom:0;left:0;width:100%;padding:10px 6px;font-size:12px;text-align:center;color:#fff;background:linear-gradient(to top,rgba(0,0,0,.95),rgba(0,0,0,.05));opacity:0;transition:.25s}.movie-card:hover .movie-name{opacity:1}@media(max-width:700px){.movie-grid{grid-template-columns:repeat(auto-fill,minmax(90px,1fr))}.top-bar{flex-direction:column}.random-btn{width:100%;height:45px}}
