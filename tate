const movieGrid=document.getElementById("movieGrid");
function renderMovies(arr){movieGrid.innerHTML="";arr.forEach(movie=>{const card=document.createElement("a");card.className="movie-card";card.href=movie.link;card.target="_blank";card.rel="noopener noreferrer";card.innerHTML=`<img src="${movie.image}" alt="${movie.title}"><div class="movie-name">${movie.title}</div>`;movieGrid.appendChild(card);});}
renderMovies(movies);
document.getElementById("searchInput").addEventListener("input",e=>{const v=e.target.value.toLowerCase();renderMovies(movies.filter(m=>m.title.toLowerCase().includes(v)));});
document.getElementById("randomBtn").addEventListener("click",()=>window.open(movies[Math.floor(Math.random()*movies.length)].link,"_blank"));
const back=document.getElementById("ice-back"),front=document.getElementById("ice-front");
function spawnBackCube(){const c=document.createElement("div");c.className="back-cube";c.style.left=Math.random()*window.innerWidth+"px";c.style.animationDuration=(8+Math.random()*6)+"s";back.appendChild(c);setTimeout(()=>c.remove(),14000);}function spawnFrontCube(){const c=document.createElement("div");c.className="front-cube";c.style.left=Math.random()*window.innerWidth+"px";c.style.animationDuration=(4+Math.random()*3)+"s";front.appendChild(c);setTimeout(()=>c.remove(),9000);}setInterval(spawnBackCube,220)
