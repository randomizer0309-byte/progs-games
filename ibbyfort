<html>
<head>
<meta charset="utf-8">
<title>CoreBall</title>
<meta name="viewport" content="width=device-width,initial-scale=1,maximum-scale=1,user-scalable=no">

<style>
body{
background:#000;
overflow:hidden;
margin:0;
font-family:Arial;
}

.center-box{
text-align:center;
position:absolute;
width:300px;
height:400px;
margin:-200px 0 0 -150px;
left:50%;
top:50%;
color:white;
}

.title{
font-size:50px;
margin-bottom:40px;
}

.play-btn{
width:160px;
height:70px;
font-size:28px;
background:white;
border:none;
border-radius:12px;
cursor:pointer;
}

.play-btn:hover{
background:#ddd;
}
</style>
</head>

<body>

<canvas id="stage"></canvas>

<div id="menu">
<section class="center-box">
<div class="title">Core Ball</div>
<button class="play-btn" onclick="startGame()">PLAY</button>
</section>
</div>

<script>
function startGame(){
document.getElementById("menu").style.display="none";
}
</script>

<script src="js/jweixin-1.0.0.js"></script>
<script src="js/index.js"></script>

</body>
</html>
