<style>
*{
    margin:0;
    padding:0;
    box-sizing:border-box;
    font-family:"Comic Sans MS",cursive;
}

:root{
    --bubble:#ff9f43;
    --bubble2:#ffbe73;
    --bubble3:#ffd9a8;
    --dark:#cc6c1c;

    --bg1:#ffe0b8;
    --bg2:#ffc277;
    --bg3:#ff9f43;
}

body{
    min-height:100vh;
    background:linear-gradient(135deg,var(--bg1),var(--bg2),var(--bg3));
    background-attachment:fixed;
    color:#4a2a12;
}

.topbar{
    max-width:1200px;
    margin:16px auto 0;
    padding:16px;

    display:flex;
    align-items:center;
    gap:12px;

    background:#fff;
    border-radius:26px;

    box-shadow:
        0 6px 0 var(--dark),
        0 14px 25px rgba(0,0,0,.18);
}

#search{
    flex:1;
    padding:12px 14px;

    border-radius:16px;
    border:3px solid var(--bubble);

    background:#fff;
    font-size:15px;
}

#search:focus{
    outline:none;
    border-color:var(--dark);
}

#counterBox{
    padding:10px 16px;
    border-radius:16px;

    background:linear-gradient(to right,var(--bubble2),var(--bubble));

    color:#fff;
    font-weight:bold;

    box-shadow:0 4px 0 var(--dark);
}

.grid{
    max-width:1200px;
    margin:auto;
    padding:18px;

    display:grid;
    grid-template-columns:repeat(auto-fill,minmax(140px,1fr));
    gap:18px;
}

.card{
    cursor:pointer;
    overflow:hidden;

    border-radius:26px;
    border:4px solid var(--bubble);

    background:#fff;

    transition:.15s;

    box-shadow:
        0 6px 0 var(--dark),
        0 14px 24px rgba(0,0,0,.18);
}

.card:hover{
    transform:translateY(-6px) scale(1.05);

    box-shadow:
        0 10px 0 var(--dark),
        0 22px 30px rgba(0,0,0,.25);
}

.thumb{
    width:100%;
    padding-top:100%;

    background-size:cover;
    background-position:center;
}

.card-title{
    padding:10px 6px;

    text-align:center;
    font-size:14px;
    font-weight:bold;

    color:#4a2a12;

    background:linear-gradient(to right,var(--bubble2),var(--bubble));
    border-top:3px solid var(--dark);

    white-space:nowrap;
    overflow:hidden;
    text-overflow:ellipsis;
}

.card.hide{
    display:none;
}
</style>

