<script>
	async function openGame(card, url) {
    const gameName =
        card.querySelector(".card-title")?.textContent.trim() || "Chicken-Nugget";

    const win = window.open("about:blank", "_blank");
    if (!win) return;

    // Initial loading screen
    win.document.open();
    win.document.write(`
        <title>${gameName}</title>
        <body style="margin:0;background:black;color:white;
        display:flex;align-items:center;justify-content:center;
        font-family:Comic Sans MS,cursive">
            Loading ${gameName}...
        </body>
    `);
    win.document.close();

    // Add favicon to the new tab
    const faviconLink = win.document.createElement("link");
    faviconLink.rel = "icon";
    faviconLink.href = "https://lh7-rt.googleusercontent.com/sitesz/AClOY7oK76fijM7B08O3S3a_efYugagyztbFe1II4ejTtTTc6fb1Em8oDkyDNj-CSzwRSOE0gSTRPJ4O_vjZcLrgmk6Rxss4jm3P6hS2qKsk8j3osIGdSF6CLt8oW-tW3yNd_O4TodRt9dRW2cfKDZWIDTs_D67_u95W2-mI-EwY9nMEiwleQOLORWgcxPmsuwNV?key=5BTnLur8qjcoLyMMzDfYSg";
    win.document.head.appendChild(faviconLink);

    try {
        const res = await fetch(url);
        const html = await res.text();

        // Inject the fetched game HTML
        win.document.open();
        win.document.write(html);
        win.document.close();

        // Ensure the title stays correct
        win.document.title = gameName;

    } catch (e) {
        win.document.open();
        win.document.write(`<h2 style='color:white'>Failed to load ${gameName}</h2>`);
        win.document.close();
    }
}

const search = document.getElementById("search");
const cards = Array.from(document.querySelectorAll(".card"));
const counterBox = document.getElementById("counterBox");

function updateCounter() {
    const visible = cards.filter(c => !c.classList.contains("hide")).length;
    counterBox.textContent = visible + " game" + (visible === 1 ? "" : "s");
}

search.addEventListener("input", () => {
    const value = search.value.toLowerCase().trim();

    cards.forEach(card => {
        const title = (card.dataset.title || card.querySelector(".card-title")?.textContent || "").toLowerCase();
        if (title.includes(value)) {
            card.classList.remove("hide");
        } else {
            card.classList.add("hide");
        }
    });

    updateCounter();
});

updateCounter();
</script>



